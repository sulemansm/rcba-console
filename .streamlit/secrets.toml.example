# .streamlit/secrets.toml.example
# Copy this file to .streamlit/secrets.toml and fill in your credentials
# IMPORTANT: .streamlit/secrets.toml is in .gitignore and should NEVER be committed

# Supabase Configuration (for Supabase Cloud)
SUPABASE_URL = "https://your-project.supabase.co"
SUPABASE_KEY = "your-anon-key-here"

# Google OAuth Configuration (get from https://console.cloud.google.com)
# Download as JSON and paste the contents as a JSON string, OR use GOOGLE_CREDENTIALS_FILE
GOOGLE_CREDENTIALS_JSON = """{"web": {"client_id": "...", "client_secret": "...", ...}}"""
# OR for local development, use file path:
GOOGLE_CREDENTIALS_FILE = "google_credentials.json"

# OAuth redirect URI (auto-detected for Streamlit Cloud, but can be overridden)
OAUTH_REDIRECT_URI = "http://localhost:8501/"

# Whitelisted email addresses (comma-separated)
WHITELISTED_EMAILS = "admin@example.com,user@example.com"

# Email Configuration (optional, for notifications)
SENDER_EMAIL = "your-email@gmail.com"
SENDER_PASSWORD = "your-app-specific-password"
SECRETARY_EMAIL = "secretary@example.com"

# Groq API (optional, for AI features)
GROQ_API_KEY = "your-groq-api-key"
